# JobApply AI — environment variable overrides
#
# You do NOT need this file for normal use.
# On first run, you will be prompted for your Google API key
# and it will be saved securely to your system keychain.
#
# Use this file if you want to override the keychain (e.g. CI/CD, servers).
# Copy to .env and fill in the values you need.

# Google Gemini — free tier (https://aistudio.google.com/apikey)
# Only needed here if you can't use the keychain (e.g. CI/CD)
GOOGLE_API_KEY=

# Optional: override the default model (gemini/gemini-2.0-flash)
LLM_MODEL=

# Job search — SerpAPI key (https://serpapi.com)
SERPAPI_KEY=
