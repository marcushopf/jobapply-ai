# JobApply AI — environment variable overrides
#
# You do NOT need this file for normal use.
# On first run, you will be prompted for your Google API key
# and it will be saved securely to your system keychain.
#
# Use this file if you want to override the keychain (e.g. CI/CD, servers),
# or to set the SerpAPI key for job search.
# Copy to .env and fill in only the values you need.
#
# Leave any line commented out (#) to keep the built-in default.

# Google Gemini — free tier (https://aistudio.google.com/apikey)
# Only needed here if you can't use the keychain (e.g. CI/CD).
GOOGLE_API_KEY=

# Job search — SerpAPI key (https://serpapi.com)
SERPAPI_KEY=

# Optional: override the default model (gemini/gemini-2.0-flash).
# Set to ollama/auto to use the best local model for your hardware automatically.
# Set to ollama/<model> (e.g. ollama/qwen2.5:7b) to pin a specific local model.
#LLM_MODEL=

# Optional: Ollama settings (for local testing or rate-limit fallback).
# Ollama runs locally — no API key needed. Install: https://ollama.com
#OLLAMA_BASE_URL=http://localhost:11434
#LLM_FALLBACK_MODEL=ollama/auto

# Optional: override the model used when refreshing integration test cache.
#TEST_LLM_MODEL=
